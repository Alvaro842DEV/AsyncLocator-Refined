{
  "schemaVersion": 1,
  "id": "asynclocator",
  "version": "${version}",
  "name": "Async Locator Refined",
  "description": "Changes the searching of features to be asynchronous to mitigate associated lag",
  "authors": [
    "alvaro842"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/async-locator-refined",
    "sources": "https://github.com/Alvaro842DEV/AsyncLocator-Refined",
    "issues": "https://github.com/Alvaro842DEV/AsyncLocator-Refined/issues"
  },
  "custom": {
    "credits": "Thanks to bright_spark, original author of Async Locator!"
  },
  "license": "MIT License",
  "icon": "logo.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "brightspark.asynclocator.AsyncLocatorModFabric"
    ],
    "fabric-gametest": [
      "brightspark.asynclocator.gametest.AsyncLocatorFabricGameTests"
    ]
  },
  "mixins": [
    "asynclocator.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "fabric-api": ">=0.116.9+1.21.1",
    "minecraft": "1.21.1",
    "java": ">=21"
  }
}
